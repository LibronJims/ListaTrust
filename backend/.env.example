# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=lista_trust

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=24h

# Email (for OTP) - Use Gmail or any SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password  # Get from Google App Password
EMAIL_FROM=ListaTrust <noreply@listatrust.com>